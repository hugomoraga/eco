# ECO Configuration Template
# Copy this to .env and fill in your values

# API Keys
MINIMAX_API_KEY=
OPENAI_API_KEY=

# Language
ECO_LANG=es

# Simulation
ECO_SEED=42
ECO_MAX_TURNS=100
ECO_AUTOPLAY=false
ECO_SNAPSHOT_INTERVAL=10

# AI Adapter
ECO_AI_ADAPTER=mock
ECO_MODEL=MiniMax-M2.7
ECO_TEMPERATURE=0.7
ECO_MAX_TOKENS=1024

# Autoplay Defaults
ECO_AUTOPLAY_MODE=autoplay
ECO_AUTOPLAY_STYLE=preservationist

# Input Mode (autoplay | hybrid | player)
ECO_INPUT_MODE=autoplay
ECO_INTERACTIVE_TURNS=5

# Output
ECO_VERBOSE=false
ECO_RUN_DIR=